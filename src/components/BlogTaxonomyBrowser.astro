---
import type { TaxonomyCount } from "../lib/blog";

type Props = {
  blogHref: string;
  categories: TaxonomyCount[];
  categoryLabel: string;
  searchHref: string;
  tagLabel: string;
  tags: TaxonomyCount[];
};

const { blogHref, categories, categoryLabel, searchHref, tagLabel, tags } = Astro.props;
---

{(categories.length > 0 || tags.length > 0) && (
  <div class="taxonomy-browsers" data-taxonomy-browsers>
    <div class="taxonomy-browser-controls">
      {categories.length > 0 && (
        <button
          id="blog-categories-heading"
          type="button"
          class="category-index-heading"
          data-taxonomy-toggle="categories"
          aria-expanded="false"
          aria-controls="blog-categories-panel"
        >
          <span>{categoryLabel}</span>
          <span class="category-index-icons" aria-hidden="true">
            <svg class="category-index-icon category-index-icon-expand" viewBox="0 0 16 16" fill="none">
              <path
                d="M3.5 6.25L8 10.75L12.5 6.25"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
              />
            </svg>
            <svg class="category-index-icon category-index-icon-collapse" viewBox="0 0 16 16" fill="none">
              <path
                d="M3.5 9.75L8 5.25L12.5 9.75"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
              />
            </svg>
          </span>
        </button>
      )}

      {tags.length > 0 && (
        <button
          type="button"
          class="category-index-heading"
          data-taxonomy-toggle="tags"
          aria-expanded="false"
          aria-controls="blog-tags-panel"
        >
          <span>{tagLabel}</span>
          <span class="category-index-icons" aria-hidden="true">
            <svg class="category-index-icon category-index-icon-expand" viewBox="0 0 16 16" fill="none">
              <path
                d="M3.5 6.25L8 10.75L12.5 6.25"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
              />
            </svg>
            <svg class="category-index-icon category-index-icon-collapse" viewBox="0 0 16 16" fill="none">
              <path
                d="M3.5 9.75L8 5.25L12.5 9.75"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
              />
            </svg>
          </span>
        </button>
      )}
    </div>

    <div class="taxonomy-browser-panels">
      {categories.length > 0 && (
        <div
          id="blog-categories-panel"
          class="category-index"
          data-taxonomy-panel="categories"
          aria-labelledby="blog-categories-heading"
          hidden
        >
          <div class="category-chip-list">
            {categories.map((category) => (
              <a class="category-chip-link" href={`${blogHref}categories/${category.slug}/`}>
                <span>{category.slug}</span>
                <span class="category-chip-count">{category.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {tags.length > 0 && (
        <div id="blog-tags-panel" class="category-index" data-taxonomy-panel="tags" hidden>
          <div class="category-chip-list">
            {tags.map((tag) => (
              <a class="category-chip-link" href={`${searchHref}?tag=${encodeURIComponent(tag.slug)}`}>
                <span>{tag.slug}</span>
                <span class="category-chip-count">{tag.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
)}

<script>
  const taxonomyGroup = document.querySelector("[data-taxonomy-browsers]");
  const taxonomyButtons = taxonomyGroup?.querySelectorAll("[data-taxonomy-toggle]");
  const taxonomyPanels = taxonomyGroup?.querySelectorAll("[data-taxonomy-panel]");

  taxonomyButtons?.forEach((button) => {
    button.addEventListener("click", () => {
      const taxonomy = button.getAttribute("data-taxonomy-toggle");
      const shouldOpen = button.getAttribute("aria-expanded") !== "true";

      taxonomyButtons.forEach((otherButton) => {
        otherButton.setAttribute("aria-expanded", "false");
      });

      taxonomyPanels?.forEach((panel) => {
        panel.hidden = true;
      });

      if (!shouldOpen || !taxonomy) {
        return;
      }

      button.setAttribute("aria-expanded", "true");

      const activePanel = taxonomyGroup?.querySelector(`[data-taxonomy-panel="${taxonomy}"]`);

      if (activePanel instanceof HTMLElement) {
        activePanel.hidden = false;
      }
    });
  });
</script>

<style>
  .taxonomy-browsers {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }

  .taxonomy-browser-controls {
    display: grid;
    gap: 1rem;
  }

  .category-index {
    display: block;
  }

  .category-index[hidden] {
    display: none !important;
  }

  .category-index-heading {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    color: var(--muted);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: left;
  }

  .category-index-icons {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    position: relative;
  }

  .category-index-icon {
    width: 1rem;
    height: 1rem;
    position: absolute;
    inset: 0;
  }

  .category-index-icon-collapse {
    display: none;
  }

  .category-index-heading[aria-expanded="true"] .category-index-icon-expand {
    display: none;
  }

  .category-index-heading[aria-expanded="true"] .category-index-icon-collapse {
    display: block;
  }

  .taxonomy-browser-panels {
    min-height: 0;
  }

  .category-chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .category-chip-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.25rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    text-decoration: none;
  }

  .category-chip-link:hover {
    color: var(--accent);
  }

  .category-chip-count {
    color: var(--muted);
    font-size: 0.85rem;
  }

  @media (min-width: 48rem) {
    .taxonomy-browser-controls {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
