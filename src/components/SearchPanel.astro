---
import type { Lang } from "../lib/site";

interface Props {
  lang: Lang;
  title: string;
  intro: string;
  placeholder: string;
  loadingLabel: string;
  emptyLabel: string;
  noResultsLabel: string;
  errorLabel: string;
  postLabel: string;
  pageLabel: string;
}

const {
  lang,
  title,
  intro,
  placeholder,
  loadingLabel,
  emptyLabel,
  noResultsLabel,
  errorLabel,
  postLabel,
  pageLabel,
} = Astro.props;
---

<section
  class="panel search-panel"
  data-search-panel
  data-index-url={`/${lang}/search-index.json`}
  data-empty-label={emptyLabel}
  data-loading-label={loadingLabel}
  data-no-results-label={noResultsLabel}
  data-error-label={errorLabel}
  data-post-label={postLabel}
  data-page-label={pageLabel}
  data-locale={lang === "es" ? "es-ES" : "en-US"}
>
  <div class="section-head">
    <div>
      <p class="eyebrow">{title}</p>
      <h2>{intro}</h2>
    </div>
  </div>

  <label class="search-box">
    <span class="search-icon" aria-hidden="true">⌕</span>
    <span class="sr-only">{title}</span>
    <input data-search-input type="search" placeholder={placeholder} autocomplete="off" />
  </label>

  <p class="search-status" data-search-status aria-live="polite">{emptyLabel}</p>
  <ol class="search-results" data-search-results></ol>
</section>

<script is:inline>
  const normalizeSearchText = (value) =>
    String(value || "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase();

  const clearChildren = (node) => {
    while (node.firstChild) {
      node.removeChild(node.firstChild);
    }
  };

  const formatDate = (date, locale) => {
    if (!date) return "";

    return new Intl.DateTimeFormat(locale, {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(date));
  };

  document.querySelectorAll("[data-search-panel]").forEach((panel) => {
    const input = panel.querySelector("[data-search-input]");
    const status = panel.querySelector("[data-search-status]");
    const resultsList = panel.querySelector("[data-search-results]");
    const labels = panel.dataset;
    const resultLimit = 8;
    let indexPromise;
    let indexedItems = [];

    const setStatus = (message) => {
      status.textContent = message;
    };

    const loadIndex = () => {
      if (!indexPromise) {
        setStatus(labels.loadingLabel);
        indexPromise = fetch(labels.indexUrl)
          .then((response) => {
            if (!response.ok) {
              throw new Error("Search index request failed");
            }

            return response.json();
          })
          .then((items) => {
            indexedItems = items.map((item) => {
              const meta = [...(item.tags || []), ...(item.categories || [])].join(" ");

              return {
                ...item,
                searchTitle: normalizeSearchText(item.title),
                searchMeta: normalizeSearchText(meta),
                searchExcerpt: normalizeSearchText(item.excerpt),
                searchText: normalizeSearchText(item.text),
              };
            });

            return indexedItems;
          })
          .catch(() => {
            setStatus(labels.errorLabel);
            return [];
          });
      }

      return indexPromise;
    };

    const scoreItem = (item, terms) => {
      let score = 0;

      for (const term of terms) {
        const titleMatch = item.searchTitle.includes(term);
        const metaMatch = item.searchMeta.includes(term);
        const excerptMatch = item.searchExcerpt.includes(term);
        const bodyMatch = item.searchText.includes(term);

        if (!titleMatch && !metaMatch && !excerptMatch && !bodyMatch) {
          return 0;
        }

        if (item.searchTitle.startsWith(term)) score += 130;
        if (titleMatch) score += 100;
        if (metaMatch) score += 45;
        if (excerptMatch) score += 25;
        if (bodyMatch) score += 8;
      }

      return score;
    };

    const renderResults = (items) => {
      clearChildren(resultsList);

      items.slice(0, resultLimit).forEach((item) => {
        const li = document.createElement("li");
        const link = document.createElement("a");
        const header = document.createElement("div");
        const badge = document.createElement("span");
        const date = document.createElement("time");
        const title = document.createElement("span");
        const excerpt = document.createElement("span");
        const typeLabel = item.type === "post" ? labels.postLabel : labels.pageLabel;
        const formattedDate = formatDate(item.date, labels.locale);

        link.className = "search-result";
        link.href = item.href;
        header.className = "search-result-header";
        badge.className = `search-result-badge is-${item.type}`;
        badge.textContent = typeLabel;
        title.className = "search-result-title";
        title.textContent = item.title;
        excerpt.className = "search-result-excerpt";
        excerpt.textContent = item.excerpt;

        header.append(badge);

        if (formattedDate) {
          date.className = "search-result-date";
          date.dateTime = item.date;
          date.textContent = formattedDate;
          header.append(date);
        }

        link.append(header, title, excerpt);
        li.append(link);
        resultsList.append(li);
      });
    };

    const runSearch = async () => {
      const query = input.value.trim();
      clearChildren(resultsList);

      if (!query) {
        setStatus(labels.emptyLabel);
        return;
      }

      const terms = normalizeSearchText(query).split(/\s+/).filter(Boolean);
      const items = await loadIndex();

      if (!terms.length || !items.length) {
        return;
      }

      const matches = items
        .map((item) => ({ item, score: scoreItem(item, terms) }))
        .filter(({ score }) => score > 0)
        .sort((a, b) => b.score - a.score)
        .map(({ item }) => item);

      if (!matches.length) {
        setStatus(labels.noResultsLabel);
        return;
      }

      setStatus("");
      renderResults(matches);
    };

    input.addEventListener("focus", loadIndex, { once: true });
    input.addEventListener("input", runSearch);
  });
</script>

<style>
  .search-panel {
    display: grid;
    gap: 1rem;
  }

  .search-panel .section-head {
    margin-bottom: 0;
  }

  .search-panel h2 {
    max-width: 42rem;
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    line-height: 1.2;
  }

  .search-box {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.8rem 1rem;
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    background: var(--surface-strong);
  }

  .search-icon {
    color: var(--accent);
    font-size: 1.35rem;
    line-height: 1;
  }

  .search-box input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    color: var(--text);
    background: transparent;
    font: inherit;
  }

  .search-box:focus-within {
    border-color: rgba(161, 79, 42, 0.46);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }

  .search-status {
    min-height: 1.4rem;
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .search-results {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .search-result {
    display: grid;
    gap: 0.55rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    background: var(--surface-soft);
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease,
      color 160ms ease;
  }

  .search-result:hover {
    color: var(--accent);
    border-color: rgba(161, 79, 42, 0.32);
    background: var(--surface);
    transform: translateY(-1px);
  }

  .search-result-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .search-result-badge,
  .search-result-date {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .search-result-badge {
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-strong);
  }

  .search-result-badge.is-post {
    border-color: rgba(161, 79, 42, 0.22);
    color: var(--accent);
  }

  .search-result-badge.is-page {
    border-color: rgba(89, 108, 137, 0.2);
  }

  .search-result-date::before {
    content: "";
    width: 0.3rem;
    height: 0.3rem;
    margin-right: 0.45rem;
    border-radius: 999px;
    background: var(--line);
    flex: none;
  }

  .search-result-title {
    display: block;
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .search-result-excerpt {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .search-result-excerpt {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 560px) {
    .search-result {
      padding: 0.95rem;
    }

    .search-result-excerpt {
      -webkit-line-clamp: 3;
    }
  }
</style>
