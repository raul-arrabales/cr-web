---
import type { TaxonomyCount } from "../lib/blog";
import type { Lang } from "../lib/site";

interface Props {
  lang: Lang;
  title: string;
  intro: string;
  placeholder: string;
  loadingLabel: string;
  emptyLabel: string;
  noResultsLabel: string;
  errorLabel: string;
  postLabel: string;
  pageLabel: string;
  filtersToggleLabel: string;
  categoryFilterLabel: string;
  tagFilterLabel: string;
  categoryPlaceholder: string;
  tagPlaceholder: string;
  clearFiltersLabel: string;
  activeFiltersLabel: string;
  noTaxonomyLabel: string;
  categoryOptions: TaxonomyCount[];
  tagOptions: TaxonomyCount[];
}

const {
  lang,
  title,
  intro,
  placeholder,
  loadingLabel,
  emptyLabel,
  noResultsLabel,
  errorLabel,
  postLabel,
  pageLabel,
  filtersToggleLabel,
  categoryFilterLabel,
  tagFilterLabel,
  categoryPlaceholder,
  tagPlaceholder,
  clearFiltersLabel,
  activeFiltersLabel,
  noTaxonomyLabel,
  categoryOptions,
  tagOptions,
} = Astro.props;
---

<section
  class="panel search-panel"
  data-search-panel
  data-index-url={`/${lang}/search-index.json`}
  data-lang={lang}
  data-empty-label={emptyLabel}
  data-loading-label={loadingLabel}
  data-no-results-label={noResultsLabel}
  data-error-label={errorLabel}
  data-post-label={postLabel}
  data-page-label={pageLabel}
  data-locale={lang === "es" ? "es-ES" : "en-US"}
  data-clear-filters-label={clearFiltersLabel}
  data-active-filters-label={activeFiltersLabel}
  data-category-filter-label={categoryFilterLabel}
  data-tag-filter-label={tagFilterLabel}
>
  <div class="section-head">
    <div>
      <p class="eyebrow">{title}</p>
      <h2>{intro}</h2>
    </div>
  </div>

  <div class="search-controls">
    <div class="search-primary">
      <label class="search-box">
        <span class="search-icon" aria-hidden="true">⌕</span>
        <span class="sr-only">{title}</span>
        <input data-search-input type="search" placeholder={placeholder} autocomplete="off" />
      </label>

      <div class="active-filters" data-active-filters hidden>
        <div class="active-filter-head">
          <p class="active-filters-label">{activeFiltersLabel}</p>
          <button type="button" class="clear-filters-link" data-clear-filters hidden>
            {clearFiltersLabel}
          </button>
        </div>
        <div class="active-filter-row">
          <div class="active-filter-list" data-active-filter-list></div>
        </div>
      </div>
    </div>

    <details class="filter-disclosure" data-filter-disclosure>
      <summary class="filter-toggle">{filtersToggleLabel}</summary>
      <div class="filter-panel">
        {
          categoryOptions.length || tagOptions.length ? (
            <>
              <div class="filter-grid">
                <label class="filter-field">
                  <span>{categoryFilterLabel}</span>
                  <input
                    type="search"
                    list={`search-categories-${lang}`}
                    placeholder={categoryPlaceholder}
                    data-filter-input="category"
                    autocomplete="off"
                  />
                </label>

                <label class="filter-field">
                  <span>{tagFilterLabel}</span>
                  <input
                    type="search"
                    list={`search-tags-${lang}`}
                    placeholder={tagPlaceholder}
                    data-filter-input="tag"
                    autocomplete="off"
                  />
                </label>
              </div>
            </>
          ) : (
            <p class="filter-empty">{noTaxonomyLabel}</p>
          )
        }
      </div>
    </details>
  </div>

  <datalist id={`search-categories-${lang}`}>
    {categoryOptions.map((option) => <option value={option.slug} label={`${option.slug} (${option.count})`} />)}
  </datalist>

  <datalist id={`search-tags-${lang}`}>
    {tagOptions.map((option) => <option value={option.slug} label={`${option.slug} (${option.count})`} />)}
  </datalist>

  <p class="search-status" data-search-status aria-live="polite">{emptyLabel}</p>
  <ol class="search-results" data-search-results></ol>
</section>

<script is:inline>
  const normalizeSearchText = (value) =>
    String(value || "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase();

  const clearChildren = (node) => {
    while (node.firstChild) {
      node.removeChild(node.firstChild);
    }
  };

  const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

  const formatDate = (date, locale) => {
    if (!date) return "";

    return new Intl.DateTimeFormat(locale, {
      year: "numeric",
      month: "short",
      day: "numeric",
    }).format(new Date(date));
  };

  document.querySelectorAll("[data-search-panel]").forEach((panel) => {
    const input = panel.querySelector("[data-search-input]");
    const status = panel.querySelector("[data-search-status]");
    const resultsList = panel.querySelector("[data-search-results]");
    const activeFilters = panel.querySelector("[data-active-filters]");
    const activeFilterList = panel.querySelector("[data-active-filter-list]");
    const clearFiltersButton = panel.querySelector("[data-clear-filters]");
    const categoryInput = panel.querySelector('[data-filter-input="category"]');
    const tagInput = panel.querySelector('[data-filter-input="tag"]');
    const disclosure = panel.querySelector("[data-filter-disclosure]");
    const labels = panel.dataset;
    const resultLimit = 8;
    const validCategories = new Set(
      [...panel.querySelectorAll(`#search-categories-${panel.dataset.lang} option`)].map((option) => option.value),
    );
    const validTags = new Set(
      [...panel.querySelectorAll(`#search-tags-${panel.dataset.lang} option`)].map((option) => option.value),
    );
    let indexPromise;
    let indexedItems = [];
    let activeTerms = [];
    let activeCategory = "";
    let activeTag = "";

    const setStatus = (message) => {
      status.textContent = message;
    };

    const syncUrl = () => {
      const url = new URL(window.location.href);

      if (activeCategory) url.searchParams.set("category", activeCategory);
      else url.searchParams.delete("category");

      if (activeTag) url.searchParams.set("tag", activeTag);
      else url.searchParams.delete("tag");

      window.history.replaceState({}, "", url);
    };

    const syncFilterInputs = () => {
      if (categoryInput) categoryInput.value = activeCategory;
      if (tagInput) tagInput.value = activeTag;
    };

    const updateClearButton = () => {
      if (!clearFiltersButton) return;
      clearFiltersButton.hidden = !(activeCategory || activeTag);
    };

    const updateActiveFilterUi = () => {
      clearChildren(activeFilterList);

      const filters = [
        activeCategory ? { type: "category", value: activeCategory } : null,
        activeTag ? { type: "tag", value: activeTag } : null,
      ].filter(Boolean);

      if (!filters.length) {
        activeFilters.hidden = true;
        updateClearButton();
        return;
      }

      activeFilters.hidden = false;
      updateClearButton();

      filters.forEach((filter) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "active-filter-pill";
        button.dataset.clearFilter = filter.type;
        const filterLabel =
          filter.type === "category" ? labels.categoryFilterLabel : labels.tagFilterLabel;
        button.textContent = `${filterLabel}: ${filter.value}`;
        activeFilterList.append(button);
      });
    };

    const loadIndex = () => {
      if (!indexPromise) {
        setStatus(labels.loadingLabel);
        indexPromise = fetch(labels.indexUrl)
          .then((response) => {
            if (!response.ok) throw new Error("Search index request failed");
            return response.json();
          })
          .then((items) => {
            indexedItems = items.map((item) => {
              const meta = [...(item.tags || []), ...(item.categories || [])].join(" ");

              return {
                ...item,
                searchTitle: normalizeSearchText(item.title),
                searchMeta: normalizeSearchText(meta),
                searchExcerpt: normalizeSearchText(item.excerpt),
                searchText: normalizeSearchText(item.text),
              };
            });

            return indexedItems;
          })
          .catch(() => {
            setStatus(labels.errorLabel);
            return [];
          });
      }

      return indexPromise;
    };

    const scoreItem = (item, terms) => {
      if (!terms.length) return 1;

      let score = 0;

      for (const term of terms) {
        const titleMatch = item.searchTitle.includes(term);
        const metaMatch = item.searchMeta.includes(term);
        const excerptMatch = item.searchExcerpt.includes(term);
        const bodyMatch = item.searchText.includes(term);

        if (!titleMatch && !metaMatch && !excerptMatch && !bodyMatch) return 0;

        if (item.searchTitle.startsWith(term)) score += 130;
        if (titleMatch) score += 100;
        if (metaMatch) score += 45;
        if (excerptMatch) score += 25;
        if (bodyMatch) score += 8;
      }

      return score;
    };

    const matchesFilters = (item) => {
      if (!activeCategory && !activeTag) return true;
      if (item.type !== "post") return false;

      const categoryMatch = !activeCategory || (item.categories || []).includes(activeCategory);
      const tagMatch = !activeTag || (item.tags || []).includes(activeTag);

      return categoryMatch && tagMatch;
    };

    const appendHighlightedText = (node, text, terms) => {
      if (!terms.length) {
        node.textContent = text;
        return;
      }

      const pattern = new RegExp(`(${terms.map(escapeRegExp).join("|")})`, "gi");
      const fragments = text.split(pattern);

      fragments.forEach((fragment) => {
        if (!fragment) return;

        const isMatch = terms.some((term) => fragment.toLowerCase() === term);

        if (isMatch) {
          const mark = document.createElement("mark");
          mark.className = "search-highlight";
          mark.textContent = fragment;
          node.append(mark);
          return;
        }

        node.append(document.createTextNode(fragment));
      });
    };

    const appendTaxonomyMeta = (container, item) => {
      if (item.type !== "post") return;

      const taxonomy = [...(item.categories || []), ...(item.tags || [])];
      if (!taxonomy.length) return;

      const metaList = document.createElement("div");
      metaList.className = "search-result-taxonomy";

      taxonomy.forEach((value) => {
        const badge = document.createElement("span");
        badge.className = "search-result-taxonomy-chip";
        badge.textContent = value;
        metaList.append(badge);
      });

      container.append(metaList);
    };

    const renderResults = (items) => {
      clearChildren(resultsList);

      items.slice(0, resultLimit).forEach((item) => {
        const li = document.createElement("li");
        const link = document.createElement("a");
        const header = document.createElement("div");
        const body = document.createElement("div");
        const badge = document.createElement("span");
        const separator = document.createElement("span");
        const date = document.createElement("time");
        const title = document.createElement("span");
        const excerpt = document.createElement("span");
        const typeLabel = item.type === "post" ? labels.postLabel : labels.pageLabel;
        const formattedDate = formatDate(item.date, labels.locale);

        link.className = "search-result";
        link.href = item.href;
        header.className = "search-result-header";
        body.className = "search-result-body";
        badge.className = `search-result-badge is-${item.type}`;
        badge.textContent = typeLabel;
        title.className = "search-result-title";
        excerpt.className = "search-result-excerpt";
        appendHighlightedText(title, item.title, activeTerms);
        appendHighlightedText(excerpt, item.excerpt, activeTerms);

        header.append(badge);

        if (formattedDate) {
          separator.className = "search-result-separator";
          separator.setAttribute("aria-hidden", "true");
          separator.textContent = "•";
          date.className = "search-result-date";
          date.dateTime = item.date;
          date.textContent = formattedDate;
          header.append(separator, date);
        }

        body.append(title, excerpt);
        appendTaxonomyMeta(body, item);
        link.append(header, body);
        li.append(link);
        resultsList.append(li);
      });
    };

    const runSearch = async () => {
      const query = input.value.trim();
      const terms = normalizeSearchText(query).split(/\s+/).filter(Boolean);
      const hasFilters = Boolean(activeCategory || activeTag);
      clearChildren(resultsList);
      activeTerms = terms;
      updateActiveFilterUi();
      syncFilterInputs();
      syncUrl();

      if (!query && !hasFilters) {
        setStatus(labels.emptyLabel);
        return;
      }

      const items = await loadIndex();
      if (!items.length) return;

      const matches = items
        .map((item) => ({ item, score: scoreItem(item, terms) }))
        .filter(({ item, score }) => score > 0 && matchesFilters(item))
        .sort((a, b) => b.score - a.score)
        .map(({ item }) => item);

      if (!matches.length) {
        setStatus(labels.noResultsLabel);
        return;
      }

      setStatus("");
      renderResults(matches);
    };

    const setInitialFiltersFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      activeCategory = params.get("category") || "";
      activeTag = params.get("tag") || "";
    };

    const applyFilters = () => {
      const nextCategory = categoryInput?.value.trim() || "";
      const nextTag = tagInput?.value.trim() || "";

      activeCategory = validCategories.has(nextCategory) ? nextCategory : "";
      activeTag = validTags.has(nextTag) ? nextTag : "";
      if (disclosure) disclosure.open = false;
      void runSearch();
    };

    const clearFilters = () => {
      activeCategory = "";
      activeTag = "";
      if (categoryInput) categoryInput.value = "";
      if (tagInput) tagInput.value = "";
      clearChildren(activeFilterList);
      activeFilters.hidden = true;
      updateClearButton();
      void runSearch();
    };

    setInitialFiltersFromUrl();
    syncFilterInputs();
    updateActiveFilterUi();

    clearFiltersButton?.addEventListener("click", clearFilters);

    [categoryInput, tagInput].forEach((field) => {
      field?.addEventListener("change", applyFilters);
      field?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          applyFilters();
        }
      });
    });

    activeFilterList.addEventListener("click", (event) => {
      const button = event.target.closest("[data-clear-filter]");
      if (!button) return;

      if (button.dataset.clearFilter === "category") activeCategory = "";
      if (button.dataset.clearFilter === "tag") activeTag = "";

      syncFilterInputs();
      void runSearch();
    });

    input.addEventListener("input", () => {
      void runSearch();
    });

    if (activeCategory || activeTag) {
      if (disclosure) disclosure.open = true;
      void runSearch();
    }
  });
</script>

<style>
  .search-panel {
    display: grid;
    gap: 1.25rem;
  }

  .search-controls {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
  }

  .search-primary {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--surface) 92%, transparent);
  }

  .search-box input,
  .filter-field input {
    width: 100%;
    border: 0;
    padding: 0;
    background: transparent;
    color: inherit;
    font: inherit;
  }

  .search-box input:focus,
  .filter-field input:focus {
    outline: none;
  }

  .search-icon {
    color: var(--muted);
  }

  .filter-disclosure {
    min-width: min(24rem, 100%);
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--surface) 96%, transparent);
  }

  .filter-toggle {
    cursor: pointer;
    list-style: none;
    padding: 0.85rem 1rem;
    font-weight: 600;
  }

  .filter-toggle::-webkit-details-marker {
    display: none;
  }

  .filter-panel {
    display: grid;
    gap: 1rem;
    padding: 0 1rem 1rem;
  }

  .filter-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .filter-field {
    display: grid;
    gap: 0.4rem;
  }

  .filter-field span,
  .active-filters-label {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

    .filter-field input {
      padding: 0.8rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 0.85rem;
      background: var(--surface);
    }

  .active-filter-head,
  .active-filter-row,
  .active-filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .filter-action-button,
  .search-panel :global(.active-filter-pill) {
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: inherit;
    font: inherit;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
  }

  .filter-empty,
  .search-status {
    margin: 0;
    color: var(--muted);
  }

  .active-filters {
    display: grid;
    gap: 0.45rem;
  }

  .active-filters[hidden] {
    display: none !important;
  }

  .active-filter-head {
    align-items: baseline;
  }

  .active-filter-row {
    align-items: center;
  }

  .clear-filters-link {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--muted);
    font: inherit;
    text-decoration: underline;
    cursor: pointer;
  }

  .search-panel :global(.active-filter-pill) {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
    background: color-mix(in srgb, var(--accent) 10%, var(--surface));
  }

  .filter-action-button:hover,
  .clear-filters-link:hover,
  .search-panel :global(.active-filter-pill:hover),
  .search-panel :global(.search-result:hover) {
    color: var(--accent);
  }

  .search-results {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.9rem;
  }

  .search-panel :global(.search-result) {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    text-decoration: none;
    background: color-mix(in srgb, var(--surface) 95%, transparent);
  }

  .search-panel :global(.search-result-header),
  .search-panel :global(.search-result-taxonomy) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .search-panel :global(.search-result-body) {
    display: grid;
    gap: 0.45rem;
  }

  .search-panel :global(.search-result-badge),
  .search-panel :global(.search-result-taxonomy-chip) {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.82rem;
  }

  .search-panel :global(.search-result-badge) {
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
  }

  .search-panel :global(.search-result-taxonomy-chip) {
    border: 1px solid var(--line);
    color: var(--muted);
  }

  .search-panel :global(.search-result-title) {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .search-panel :global(.search-result-date),
  .search-panel :global(.search-result-separator),
  .search-panel :global(.search-result-excerpt) {
    color: var(--muted);
  }

  .search-panel :global(.search-highlight) {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    color: inherit;
  }

  @media (max-width: 720px) {
    .search-controls {
      grid-template-columns: 1fr;
    }

    .filter-grid {
      grid-template-columns: 1fr;
    }

    .active-filters {
      align-items: flex-start;
    }
  }
</style>
