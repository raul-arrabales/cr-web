---
import { sectionRoutes, siteCopy, type Lang } from "../lib/site";

interface Props {
  lang?: Lang;
  updatedAt?: Date;
}

const { lang = "en", updatedAt = new Date() } = Astro.props;
const copy = siteCopy[lang];
const routes = sectionRoutes[lang];

const formatter = new Intl.DateTimeFormat(lang === "es" ? "es-ES" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<footer class="site-footer">
  <nav class="footer-links" aria-label={lang === "es" ? "Enlaces del pie" : "Footer links"}>
    <a href="#top">{copy.backToTopLabel}</a>
    <a href={routes.welcome}>{copy.welcomeLabel}</a>    
    <a href={routes.home}>{copy.homeLabel}</a>
    <a href={routes.search}>{copy.searchLabel}</a>
    <a href={routes.contact}>{copy.contactLabel}</a>
    <a href="https://www.linkedin.com/in/raularrabales/" rel="noreferrer" target="_blank">LinkedIn</a>
    <a href="https://github.com/raul-arrabales" rel="noreferrer" target="_blank">GitHub</a>
  </nav>

  <div class="footer-meta">
    <p>{copy.footerUpdatedLabel}: <time datetime={updatedAt.toISOString()}>{formatter.format(updatedAt)}</time></p>
    <p>
      {copy.footerLicenseLead}{" "}
      <a href="https://creativecommons.org/licenses/by-nc-sa/3.0/" rel="license noreferrer" target="_blank">
        {copy.footerLicenseLinkLabel}
      </a>
      . {copy.footerTrademarkNotice}
    </p>
    <p>{copy.footerDisclaimer}</p>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-top: 2rem;
    padding: 1rem 1.15rem 0;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .footer-meta p {
    margin: 0;
  }

  .footer-meta p + p {
    margin-top: 0.45rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .footer-links a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
  }

  .footer-meta a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
  }

  .site-footer a:hover {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .site-footer {
      padding-inline: 0;
    }
  }
</style>
