---
type Props = {
  href: string;
  label: string;
  count?: number;
  tone?: "default" | "muted";
};

const { href, label, count, tone = "default" } = Astro.props;
---

<a class:list={["taxonomy-chip", tone === "muted" && "is-muted"]} href={href}>
  <span>{label}</span>
  {typeof count === "number" && <span class="taxonomy-chip-count">{count}</span>}
</a>

<style>
  .taxonomy-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2rem;
    padding: 0.32rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: inherit;
    text-decoration: none;
    font-size: 0.88rem;
    background: color-mix(in srgb, var(--surface) 94%, transparent);
  }

  .taxonomy-chip:hover {
    color: var(--accent);
  }

  .taxonomy-chip.is-muted {
    color: var(--muted);
  }

  .taxonomy-chip-count {
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>
