---
import "../styles/fonts.css";
import "../styles/site-chrome.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ThemeBoot from "../components/ThemeBoot.astro";
import type { Lang, NavItem } from "../lib/site";
import { getNavItems } from "../lib/site";

interface Props {
  title: string;
  lang: Lang;
  description?: string;
  navItems?: NavItem[];
  updatedAt?: Date;
}

const { title, lang, description, navItems = getNavItems(lang), updatedAt = new Date() } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <ThemeBoot />
    <style>
      .prose {
        font-size: 1.05rem;
        line-height: 1.75;
      }

      .prose,
      .prose p,
      .prose li {
        color: var(--text);
      }

      .prose > :first-child {
        margin-top: 0;
      }

      .prose > :last-child {
        margin-bottom: 0;
      }

      .prose h1,
      .prose h2,
      .prose h3 {
        font-family: "Space Grotesk", sans-serif;
        line-height: 1.15;
      }

      .prose :where(h1, h2, h3, h4, h5, h6, [id]) {
        scroll-margin-top: var(--site-header-offset);
      }

      .prose h1 {
        margin-top: 0;
        font-size: clamp(2rem, 3.6vw, 3.5rem);
      }

      .prose img {
        max-width: 100%;
        height: auto;
        border-radius: 1rem;
      }

      .prose figure {
        margin: 1.75rem 0;
      }

      .prose figcaption {
        margin-top: 0.75rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .prose a {
        color: var(--accent);
      }

      .prose hr {
        border: 0;
        border-top: 1px solid var(--line);
        margin: 2rem 0;
      }

      .prose ul,
      .prose ol {
        padding-left: 1.2rem;
      }

      .prose li + li {
        margin-top: 0.45rem;
      }

      .prose blockquote {
        margin: 1.5rem 0;
        padding-left: 1rem;
        border-left: 3px solid var(--accent);
        color: var(--muted);
      }

      .prose table {
        width: 100%;
        margin: 1.75rem 0;
        border-collapse: collapse;
        border: 1px solid var(--line);
        border-radius: 1rem;
        overflow: hidden;
        background: transparent;
      }

      .prose th,
      .prose td {
        padding: 0.85rem 1rem;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }

      .prose th {
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--muted);
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.18);
      }

      .prose tr:last-child td {
        border-bottom: 0;
      }

      .prose iframe {
        display: block;
        width: 100%;
        max-width: 100%;
        margin: 1.75rem 0;
        border: 1px solid var(--line);
        border-radius: 0.5rem;
        background: transparent;
      }

      .eyebrow {
        margin: 0 0 0.8rem;
        color: var(--muted);
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .lede {
        color: var(--muted);
        font-size: 1.08rem;
      }

      @media (max-width: 720px) {
        .prose {
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body id="top">
    <div class="shell">
      <SiteHeader
        brandHref={`/${lang}/`}
        brandLabel="Conscious Robots"
        currentLang={lang}
        uiLang={lang}
        navItems={navItems}
        navLabel={lang === "es" ? "Menú principal" : "Main menu"}
      />

      <main>
        <slot />
      </main>

      <SiteFooter lang={lang} updatedAt={updatedAt} />
    </div>
  </body>
</html>
