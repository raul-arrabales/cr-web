---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { type Lang, siteCopy } from "../../../lib/site";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog");

  return (["en", "es"] as const).flatMap((lang) => {
    const langPosts = posts
      .filter((post) => post.id.startsWith(`${lang}/`))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .map((post) => {
        const [, year, slug] = post.id.split("/");

        return {
          title: post.data.title,
          date: post.data.date,
          href: `/${lang}/blog/${year}/${slug}/`,
          excerpt: (() => {
            const cleaned = post.body
              .replace(/```[\s\S]*?```/g, " ")
              .replace(/!\[[^\]]*\]\([^)]+\)/g, " ")
              .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
              .replace(/<[^>]+>/g, " ")
              .replace(/[*_>#`~=-]/g, " ")
              .replace(/\s+/g, " ")
              .trim();

            const words = cleaned.split(" ").filter(Boolean);
            const excerpt = words.slice(0, 14).join(" ");

            return words.length > 14 ? `${excerpt}…` : excerpt;
          })(),
        };
      });

    return paginate(langPosts, {
      pageSize: 20,
      params: { lang },
    });
  });
}

const { lang } = Astro.params as { lang: Lang };
const copy = siteCopy[lang];
const { page } = Astro.props;

const formatter = new Intl.DateTimeFormat(copy.dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<SiteLayout lang={lang} title={`Raúl Arrabales | ${copy.blogLabel}`} description={copy.blogIntro}>
  <section class="panel">
    <div class="prose">
      <p class="eyebrow">{copy.myName}</p>
      <h1>{copy.blogLabel}</h1>
      <p class="lede">{copy.blogIntro}</p>
    </div>
  </section>

  <section class="panel list-panel">
    <nav id="blog-pagination" class="pagination pagination-top" aria-label={copy.paginationLabel}>
      <a
        class:list={["pagination-link", !page.url.prev && "is-disabled"]}
        href={page.url.prev ? `${page.url.prev}#blog-pagination` : undefined}
      >
        {copy.previousPageLabel}
      </a>
      <span class="pagination-state">
        {page.currentPage} / {page.lastPage}
      </span>
      <a
        class:list={["pagination-link", !page.url.next && "is-disabled"]}
        href={page.url.next ? `${page.url.next}#blog-pagination` : undefined}
      >
        {copy.nextPageLabel}
      </a>
    </nav>

    <ul class="post-list">
      {page.data.map((post) => (
        <li class="post-item">
          <a class="post-link" href={post.href}>
            <h2>{post.title}</h2>
            <time datetime={post.date.toISOString()}>{formatter.format(post.date)}</time>
            <p class="excerpt">{post.excerpt}</p>
          </a>
        </li>
      ))}
    </ul>

    <nav class="pagination" aria-label={copy.paginationLabel}>
      <a
        class:list={["pagination-link", !page.url.prev && "is-disabled"]}
        href={page.url.prev ? `${page.url.prev}#blog-pagination` : undefined}
      >
        {copy.previousPageLabel}
      </a>
      <span class="pagination-state">
        {page.currentPage} / {page.lastPage}
      </span>
      <a
        class:list={["pagination-link", !page.url.next && "is-disabled"]}
        href={page.url.next ? `${page.url.next}#blog-pagination` : undefined}
      >
        {copy.nextPageLabel}
      </a>
    </nav>
  </section>

  <style>
    .list-panel {
      margin-top: 1.25rem;
    }

    .pagination-top {
      margin-bottom: 1.25rem;
      position: sticky;
      top: 1rem;
      z-index: 2;
      padding: 0.75rem 0;
      background: var(--surface);
      border-radius: 0.75rem;
      backdrop-filter: blur(12px);
      scroll-margin-top: clamp(4rem, 7vw, 5.5rem);
    }

    .page-count {
      margin: 1rem 0 0;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .post-list {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid var(--line);
    }

    .post-item {
      border-bottom: 1px solid var(--line);
    }

    .post-link {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: center;
      padding: 1rem 0;
      text-decoration: none;
    }

    .post-link:hover {
      color: var(--accent);
    }

    .post-link h2 {
      margin: 0;
      font-size: 1.2rem;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .post-link time {
      color: var(--muted);
      white-space: nowrap;
      font-size: 0.95rem;
    }

    .excerpt {
      grid-column: 1;
      margin: 0;
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.45;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .pagination {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: space-between;
      align-items: center;
      margin-top: 1.25rem;
    }

    .pagination-link {
      display: inline-flex;
      align-items: center;
      min-height: 2.4rem;
      padding: 0.45rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
      text-decoration: none;
    }

    .pagination-link:hover {
      color: var(--accent);
    }

    .pagination-link.is-disabled {
      visibility: hidden;
      pointer-events: none;
    }

    .pagination-state {
      color: var(--muted);
      font-size: 0.95rem;
    }
  </style>
</SiteLayout>
