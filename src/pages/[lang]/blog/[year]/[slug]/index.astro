---
import { getCollection, render } from "astro:content";
import TaxonomyChip from "../../../../../components/TaxonomyChip.astro";
import SiteLayout from "../../../../../layouts/SiteLayout.astro";
import { getBlogPostRoute } from "../../../../../lib/blog";
import { siteCopy, type Lang } from "../../../../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    const [lang, year, slug] = post.id.split("/");

    return {
      params: { lang, year, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = Astro.params.lang as Lang;
const copy = siteCopy[lang];

const siblingPosts = (await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`))).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const currentPostIndex = siblingPosts.findIndex((entry) => entry.id === post.id);
const previousPost =
  currentPostIndex >= 0 ? siblingPosts[currentPostIndex + 1] : undefined;
const nextPost = currentPostIndex > 0 ? siblingPosts[currentPostIndex - 1] : undefined;

const formatter = new Intl.DateTimeFormat(copy.dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const categories = post.data.categories ?? [];
const tags = post.data.tags ?? [];
---

<SiteLayout lang={lang} title={post.data.title}>
  <article class="panel prose">
    <div class="post-meta">
      <p class="eyebrow">{formatter.format(post.data.date)}</p>
      {(categories.length > 0 || tags.length > 0) && (
        <div class="taxonomy-badges" aria-label="Post taxonomy">
          {categories.map((category) => (
            <TaxonomyChip href={`/${lang}/blog/categories/${category}/`} label={category} />
          ))}
          {tags.map((tag) => (
            <TaxonomyChip
              href={`/${lang}/search/?tag=${encodeURIComponent(tag)}`}
              label={tag}
              tone="muted"
            />
          ))}
        </div>
      )}
    </div>
    <h1>{post.data.title}</h1>
    <Content />
  </article>

  {(previousPost || nextPost) && (
    <nav class="panel post-nav" aria-label={copy.blogLabel}>
      {previousPost ? (
        <a class="post-nav-card post-nav-card-previous" href={getBlogPostRoute(previousPost).href}>
          <span class="post-nav-label">{copy.previousPostLabel}</span>
          <span class="post-nav-title">{previousPost.data.title}</span>
        </a>
      ) : (
        <div aria-hidden="true"></div>
      )}

      {nextPost ? (
        <a class="post-nav-card post-nav-card-next" href={getBlogPostRoute(nextPost).href}>
          <span class="post-nav-label">{copy.nextPostLabel}</span>
          <span class="post-nav-title">{nextPost.data.title}</span>
        </a>
      ) : (
        <div aria-hidden="true"></div>
      )}
    </nav>
  )}

  <style>
    .post-meta {
      display: grid;
      gap: 0.75rem;
    }

    .taxonomy-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-bottom: 0.35rem;
    }

    .post-nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.25rem;
    }

    .post-nav-card {
      display: grid;
      gap: 0.45rem;
      min-height: 100%;
      padding: 1.1rem 1.15rem;
      border: 1px solid var(--line);
      border-radius: 1.1rem;
      background: linear-gradient(135deg, var(--surface), var(--surface-soft));
      text-decoration: none;
      transition: border-color 180ms ease, transform 180ms ease, color 180ms ease;
    }

    .post-nav-card:hover {
      color: var(--accent);
      border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
      transform: translateY(-1px);
    }

    .post-nav-card-next {
      text-align: right;
    }

    .post-nav-label {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .post-nav-title {
      font-size: 1.02rem;
      font-weight: 600;
      line-height: 1.4;
      text-wrap: balance;
    }

    @media (max-width: 640px) {
      .post-nav {
        grid-template-columns: 1fr;
      }

      .post-nav-card-next {
        text-align: left;
      }
    }
  </style>
</SiteLayout>
