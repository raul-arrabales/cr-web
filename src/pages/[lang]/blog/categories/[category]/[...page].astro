---
import { getCollection } from "astro:content";
import BlogPostRow from "../../../../../components/BlogPostRow.astro";
import { filterPostsByCategory, getCategoryCounts, toBlogPostListItem } from "../../../../../lib/blog";
import SiteLayout from "../../../../../layouts/SiteLayout.astro";
import { type Lang, siteCopy } from "../../../../../lib/site";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog");
  const languages = ["en", "es"] as const;

  return languages.flatMap((lang) => {
    const langPosts = posts.filter((post) => post.id.startsWith(`${lang}/`));
    const categories = getCategoryCounts(langPosts, lang);

    return categories.flatMap((category) => {
      const categoryPosts = filterPostsByCategory(langPosts, category.slug)
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map((post) => toBlogPostListItem(post));

      return paginate(categoryPosts, {
        pageSize: 20,
        params: { lang, category: category.slug },
        props: { categoryCount: category.count },
      });
    });
  });
}

const { lang, category } = Astro.params as { lang: Lang; category: string };
const copy = siteCopy[lang];
const { page, categoryCount } = Astro.props as {
  page: {
    data: ReturnType<typeof toBlogPostListItem>[];
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string };
  };
  categoryCount: number;
};

const formatter = new Intl.DateTimeFormat(copy.dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<SiteLayout
  lang={lang}
  title={`Raúl Arrabales | ${copy.blogCategoryArchiveTitle}: ${category}`}
  description={`${copy.blogCategoryArchiveIntro} ${category}`}
>
  <section class="panel prose">
    <p class="eyebrow">{copy.blogCategoryArchiveTitle}</p>
    <h1>{category}</h1>
    <p class="lede">
      {copy.blogCategoryArchiveIntro} {categoryCount}
    </p>
    <a class="back-link" href={`/${lang}/blog/`}>
      {copy.blogBackToArchiveLabel}
    </a>
  </section>

  <section class="panel list-panel">
    <nav id="blog-pagination" class="pagination pagination-top" aria-label={copy.paginationLabel}>
      <a
        class:list={["pagination-link", !page.url.prev && "is-disabled"]}
        href={page.url.prev ? `${page.url.prev}#blog-pagination` : undefined}
      >
        {copy.previousPageLabel}
      </a>
      <span class="pagination-state">
        {page.currentPage} / {page.lastPage}
      </span>
      <a
        class:list={["pagination-link", !page.url.next && "is-disabled"]}
        href={page.url.next ? `${page.url.next}#blog-pagination` : undefined}
      >
        {copy.nextPageLabel}
      </a>
    </nav>

    <ul class="post-list">
      {page.data.map((post) => (
        <li class="post-item">
          <BlogPostRow
            variant="archive"
            title={post.title}
            href={post.href}
            date={post.date}
            formatter={formatter}
            excerpt={post.excerpt}
          />
        </li>
      ))}
    </ul>

    <nav class="pagination" aria-label={copy.paginationLabel}>
      <a
        class:list={["pagination-link", !page.url.prev && "is-disabled"]}
        href={page.url.prev ? `${page.url.prev}#blog-pagination` : undefined}
      >
        {copy.previousPageLabel}
      </a>
      <span class="pagination-state">
        {page.currentPage} / {page.lastPage}
      </span>
      <a
        class:list={["pagination-link", !page.url.next && "is-disabled"]}
        href={page.url.next ? `${page.url.next}#blog-pagination` : undefined}
      >
        {copy.nextPageLabel}
      </a>
    </nav>
  </section>

  <style>
    .back-link {
      display: inline-flex;
      align-items: center;
      min-height: 2.2rem;
      padding: 0.45rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      text-decoration: none;
    }

    .back-link:hover {
      color: var(--accent);
    }

    .list-panel {
      margin-top: 1.25rem;
    }

    .pagination-top {
      margin-bottom: 1.25rem;
      position: sticky;
      top: 1rem;
      z-index: 2;
      padding: 0.75rem 0;
      background: var(--surface);
      border-radius: 0.75rem;
      backdrop-filter: blur(12px);
      scroll-margin-top: clamp(4rem, 7vw, 5.5rem);
    }

    .post-list {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid var(--line);
    }

    .post-item {
      border-bottom: 1px solid var(--line);
    }

    .pagination {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: space-between;
      align-items: center;
      margin-top: 1.25rem;
    }

    .pagination-link {
      display: inline-flex;
      align-items: center;
      min-height: 2.4rem;
      padding: 0.45rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
      text-decoration: none;
    }

    .pagination-link:hover {
      color: var(--accent);
    }

    .pagination-link.is-disabled {
      visibility: hidden;
      pointer-events: none;
    }

    .pagination-state {
      color: var(--muted);
      font-size: 0.95rem;
    }
  </style>
</SiteLayout>
