---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { type Lang, siteCopy } from "../../../lib/site";

export async function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const copy = siteCopy[lang];

const posts = (await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => {
    const [, year, slug] = post.id.split("/");

    return {
      title: post.data.title,
      date: post.data.date,
      href: `/${lang}/blog/${year}/${slug}/`,
      excerpt: getExcerpt(post.body),
    };
  });

const formatter = new Intl.DateTimeFormat(lang === "es" ? "es-ES" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

function getExcerpt(body: string, maxWords = 14) {
  const cleaned = body
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/!\[[^\]]*\]\([^)]+\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/[*_>#`~=-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  const words = cleaned.split(" ").filter(Boolean);
  const excerpt = words.slice(0, maxWords).join(" ");

  return words.length > maxWords ? `${excerpt}…` : excerpt;
}
---

<SiteLayout lang={lang} title={`Raúl Arrabales | ${copy.blogLabel}`} description={copy.blogIntro}>
  <section class="panel">
    <div class="prose">
      <p class="eyebrow">{copy.myName}</p>
      <h1>{copy.blogLabel}</h1>
      <p class="lede">{copy.blogIntro}</p>
    </div>
  </section>

  <section class="panel list-panel">
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a class="post-link" href={post.href}>
            <h2>{post.title}</h2>
            <time datetime={post.date.toISOString()}>{formatter.format(post.date)}</time>
            <p class="excerpt">{post.excerpt}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .list-panel {
      margin-top: 1.25rem;
    }

    .post-list {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid var(--line);
    }

    .post-item {
      border-bottom: 1px solid var(--line);
    }

    .post-link {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: center;
      padding: 1rem 0;
      text-decoration: none;
    }

    .post-link:hover {
      color: var(--accent);
    }

    .post-link h2 {
      margin: 0;
      font-size: 1.2rem;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .post-link time {
      color: var(--muted);
      white-space: nowrap;
      font-size: 0.95rem;
    }

    .excerpt {
      grid-column: 1;
      margin: 0;
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.45;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  </style>
</SiteLayout>
