---
import { getCollection } from "astro:content";
import BlogPostRow from "../../components/BlogPostRow.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getPostExcerpt } from "../../lib/blog";
import { type Lang, siteCopy, sectionRoutes } from "../../lib/site";

export async function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const copy = siteCopy[lang];
const routes = sectionRoutes[lang];

const posts = (await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6)
  .map((post) => {
    const [, year, slug] = post.id.split("/");

    return {
      title: post.data.title,
      date: post.data.date,
      href: `/${lang}/blog/${year}/${slug}/`,
      excerpt: getPostExcerpt(post.body),
    };
  });

const formatter = new Intl.DateTimeFormat(copy.dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<SiteLayout lang={lang} title={`Raúl Arrabales | ${copy.homeLabel}`} description={copy.homeIntro}>
  <section class="panel">
    <div class="prose">
      <p class="eyebrow">{copy.exploreLabel}</p>
      <h1>{copy.siteTitle}</h1>
      <p class="lede">{copy.homeIntro}</p>
      <div class="intro-card">
        <p>{copy.homeSummary}</p>
      </div>
    </div>
  </section>

  <section class="panel recent-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">{copy.blogLabel}</p>
        <h2>{copy.recentPostsLabel}</h2>
      </div>
      <a class="browse-all" href={routes.blog}>{copy.blogLabel}</a>
    </div>

    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <BlogPostRow
            variant="compact"
            title={post.title}
            href={post.href}
            date={post.date}
            formatter={formatter}
            excerpt={post.excerpt}
          />
        </li>
      ))}
    </ul>
  </section>

  <section class="panel">
    <div class="search-cta">
      <div class="search-cta-copy">
        <p class="search-cta-label">{copy.searchLabel}</p>
        <p>{copy.searchIntro}</p>
      </div>
      <a class="browse-all search-cta-link" href={routes.search}>{copy.searchLabel}</a>
    </div>
  </section>

  <style>
    .panel + .panel {
      margin-top: 1.25rem;
    }

    .browse-all {
      text-decoration: none;
    }

    .intro-card {
      max-width: 44rem;
      margin-top: 1.35rem;
      padding: 1rem 1.1rem;
      border: 1px solid var(--line);
      border-radius: 1.1rem;
      background: linear-gradient(135deg, var(--surface-strong), var(--surface-soft));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.24);
    }

    .intro-card p {
      margin: 0;
      color: var(--text);
      font-size: 1rem;
      line-height: 1.65;
    }

    .browse-all:hover {
      color: var(--accent);
    }

    .search-cta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
    }

    .search-cta-copy {
      flex: 1 1 24rem;
      max-width: 40rem;
    }

    .search-cta-copy p {
      margin: 0;
    }

    .search-cta-label {
      margin-bottom: 0.3rem;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .search-cta-link {
      flex: none;
    }

    .section-head {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: end;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .section-head h2 {
      margin: 0;
      font-size: 1.6rem;
    }

    .browse-all {
      display: inline-flex;
      align-items: center;
      min-height: 2.4rem;
      padding: 0.5rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
    }

    .post-list {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid var(--line);
    }

    .post-item {
      border-bottom: 1px solid var(--line);
    }

    @media (max-width: 640px) {
      .search-cta {
        align-items: start;
      }
    }
  </style>
</SiteLayout>
