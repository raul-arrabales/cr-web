---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { type Lang, siteCopy, sectionRoutes } from "../../lib/site";

export async function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const copy = siteCopy[lang];
const routes = sectionRoutes[lang];

const posts = (await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6)
  .map((post) => {
    const [, year, slug] = post.id.split("/");

    return {
      title: post.data.title,
      date: post.data.date,
      href: `/${lang}/blog/${year}/${slug}/`,
    };
  });

const formatter = new Intl.DateTimeFormat(lang === "es" ? "es-ES" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<SiteLayout lang={lang} title={`Raúl Arrabales | ${copy.homeLabel}`} description={copy.homeIntro}>
  <section class="panel">
    <div class="prose">
      <p class="eyebrow">{copy.exploreLabel}</p>
      <h1>{copy.siteTitle}</h1>
      <p class="lede">{copy.homeIntro}</p>
    </div>
  </section>

  <section class="panel recent-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">{copy.blogLabel}</p>
        <h2>{copy.recentPostsLabel}</h2>
      </div>
      <a class="browse-all" href={routes.blog}>{copy.blogLabel}</a>
    </div>

    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a class="post-link" href={post.href}>
            <span>{post.title}</span>
            <time datetime={post.date.toISOString()}>{formatter.format(post.date)}</time>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .panel + .panel {
      margin-top: 1.25rem;
    }

    .quick-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.8rem;
      margin-top: 1.5rem;
    }

    .quick-link,
    .browse-all,
    .post-link {
      text-decoration: none;
    }

    .quick-link {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 4rem;
      padding: 1rem;
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: var(--surface);
      font-size: 1.05rem;
    }

    .quick-link:hover,
    .browse-all:hover,
    .post-link:hover {
      color: var(--accent);
    }

    .section-head {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: end;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .section-head h2 {
      margin: 0;
      font-size: 1.6rem;
    }

    .browse-all {
      display: inline-flex;
      align-items: center;
      min-height: 2.4rem;
      padding: 0.5rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
    }

    .post-list {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid var(--line);
    }

    .post-item {
      border-bottom: 1px solid var(--line);
    }

    .post-link {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      align-items: baseline;
      justify-content: space-between;
      padding: 1rem 0;
    }

    .post-link time {
      color: var(--muted);
      font-size: 0.95rem;
      white-space: nowrap;
    }

    @media (max-width: 820px) {
      .quick-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .quick-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</SiteLayout>
