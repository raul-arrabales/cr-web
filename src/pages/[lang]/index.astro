---
import { getCollection } from "astro:content";
import BlogPostRow from "../../components/BlogPostRow.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getPostExcerpt } from "../../lib/blog";
import { type Lang, siteCopy, sectionRoutes } from "../../lib/site";

export async function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const copy = siteCopy[lang];
const routes = sectionRoutes[lang];

const posts = (await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6)
  .map((post) => {
    const [, year, slug] = post.id.split("/");

    return {
      title: post.data.title,
      date: post.data.date,
      href: `/${lang}/blog/${year}/${slug}/`,
      excerpt: getPostExcerpt(post.body),
    };
  });

const formatter = new Intl.DateTimeFormat(copy.dateLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<SiteLayout lang={lang} title={`Raúl Arrabales | ${copy.homeLabel}`} description={copy.homeIntro}>
  <section class="panel">
    <div class="prose">
      <p class="eyebrow">{copy.exploreLabel}</p>
      <h1>{copy.siteTitle}</h1>
      <p class="lede">{copy.homeIntro}</p>
    </div>
  </section>

  <section class="panel recent-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">{copy.blogLabel}</p>
        <h2>{copy.recentPostsLabel}</h2>
      </div>
      <a class="browse-all" href={routes.blog}>{copy.blogLabel}</a>
    </div>

    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <BlogPostRow
            variant="compact"
            title={post.title}
            href={post.href}
            date={post.date}
            formatter={formatter}
            excerpt={post.excerpt}
          />
        </li>
      ))}
    </ul>
  </section>

  <style>
    .panel + .panel {
      margin-top: 1.25rem;
    }

    .browse-all {
      text-decoration: none;
    }

    .browse-all:hover {
      color: var(--accent);
    }

    .section-head {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: end;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .section-head h2 {
      margin: 0;
      font-size: 1.6rem;
    }

    .browse-all {
      display: inline-flex;
      align-items: center;
      min-height: 2.4rem;
      padding: 0.5rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
    }

    .post-list {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid var(--line);
    }

    .post-item {
      border-bottom: 1px solid var(--line);
    }
  </style>
</SiteLayout>
