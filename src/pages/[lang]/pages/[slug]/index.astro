---
import { getCollection, render } from "astro:content";
import ContactForm from "../../../../components/ContactForm.astro";
import SiteLayout from "../../../../layouts/SiteLayout.astro";
import { getMediaHubItems, type Lang } from "../../../../lib/site";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => {
    const [lang, slug] = page.id.split("/");

    return {
      params: { lang, slug },
      props: { page },
    };
  });
}

const { page } = Astro.props;
const { Content } = await render(page);
const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug ?? "";
const isMediaHub = slug === "media-presence" || slug === "presencia-en-medios";
const isContactPage = slug === "contact-me" || slug === "contacto";
const isPublicationsPage = slug === "publications" || slug === "publicaciones";
const isPodcastPage = slug === "podcast";
const isMediaArchivePage = slug === "media-appearances" || slug === "medios";
const isTalksArchivePage = slug === "invited-talks" || slug === "conferencias";
const isEventsPage = slug === "upcoming-events" || slug === "proximos-eventos";
const isCvPage = slug === "cv-english" || slug === "curriculum";
const isBookLandingPage =
  slug === "mental-disorders-in-artificial-intelligence-book" ||
  slug === "los-trastornos-mentales-de-la-inteligencia-artificial-libro";
const mediaHubItems = isMediaHub ? getMediaHubItems(lang) : [];
const mediaHubIntro =
  lang === "es"
    ? {
        lead: "Una vista rápida de la actividad pública de Raúl Arrabales en medios, charlas, podcasts y próximos encuentros.",
        note: "Explora los distintos formatos para seguir conversaciones, entrevistas y apariciones relacionadas con inteligencia artificial, psicología y tecnología.",
      }
    : {
        lead: "A quick overview of Raúl Arrabales' public-facing work across media, talks, podcasts, and upcoming events.",
        note: "Browse different formats for following interviews, conversations, and appearances related to artificial intelligence, psychology, and technology.",
      };
---

<SiteLayout lang={lang} title={page.data.title}>
  <article
    class:list={[
      "panel prose page-panel",
      isPublicationsPage && "is-publications-page",
      isPodcastPage && "is-podcast-page",
      isMediaArchivePage && "is-media-archive-page",
      isTalksArchivePage && "is-talks-archive-page",
      isEventsPage && "is-events-page",
      isCvPage && "is-cv-page",
      isBookLandingPage && "is-book-landing-page",
    ]}
  >
    <h1>{page.data.title}</h1>
    {isMediaHub ? (
      <>
        <div class="media-hub-intro">
          <p>{mediaHubIntro.lead}</p>
          <p class="media-hub-note">{mediaHubIntro.note}</p>
        </div>
        <div class="media-hub">
          {mediaHubItems.map((item) => (
            <a class="media-card" href={item.href}>
              <h2>{item.title}</h2>
              <p>{item.description}</p>
            </a>
          ))}
        </div>
      </>
    ) : (
      <>
        <Content />
        {isContactPage && <ContactForm lang={lang} />}
      </>
    )}
  </article>

  <style>
    .page-panel {
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
    }

    .page-panel.is-cv-page {
      max-width: 72rem;
      --cv-label-column-width: 10rem;
    }

    .page-panel.is-cv-page > h1 {
      margin-bottom: 1.1rem;
    }

    .page-panel.is-cv-page :global(.cv-hero) {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(13rem, 17rem);
      gap: 1.5rem;
      align-items: start;
      margin: 1.4rem 0 2rem;
      padding: 1.4rem;
      border: 1px solid var(--line);
      border-radius: 1.4rem;
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 9%, transparent), transparent 54%),
        linear-gradient(180deg, color-mix(in srgb, var(--surface) 95%, white 5%), var(--surface));
      box-shadow: var(--shadow);
    }

    .page-panel.is-cv-page :global(.cv-hero-copy > :first-child),
    .page-panel.is-cv-page :global(.cv-links > :first-child),
    .page-panel.is-cv-page :global(.cv-links > p:first-child) {
      margin-top: 0;
    }

    .page-panel.is-cv-page :global(.cv-kicker) {
      margin: 0 0 0.7rem;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .page-panel.is-cv-page :global(.cv-summary) {
      margin: 0 0 1rem;
      font-size: clamp(1.15rem, 2vw, 1.45rem);
      line-height: 1.35;
    }

    .page-panel.is-cv-page :global(.cv-mission) {
      margin: 0;
      color: var(--muted);
    }

    .page-panel.is-cv-page :global(.cv-photo-frame) {
      justify-self: end;
      width: min(100%, 16rem);
      padding: 0.75rem;
      border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
      border-radius: 1.35rem;
      background: color-mix(in srgb, var(--surface) 88%, white 12%);
      box-shadow: var(--shadow);
    }

    .page-panel.is-cv-page :global(.cv-photo-frame img) {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: center top;
      border-radius: 1rem;
      box-shadow: none;
    }

    .page-panel.is-cv-page :global(.cv-meta),
    .page-panel.is-cv-page :global(.cv-index),
    .page-panel.is-cv-page :global(.cv-links) {
      margin: 1rem 0 0;
      padding: 1rem 1.1rem;
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: color-mix(in srgb, var(--surface) 92%, white 8%);
    }

    .page-panel.is-cv-page :global(.cv-meta) {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .page-panel.is-cv-page :global(.cv-meta-item) {
      margin: 0;
    }

    .page-panel.is-cv-page :global(.cv-meta-label) {
      display: block;
      margin-bottom: 0.3rem;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .page-panel.is-cv-page :global(.cv-links p) {
      margin: 0;
    }

    .page-panel.is-cv-page :global(.cv-links a + a) {
      margin-left: 0.9rem;
    }

    .page-panel.is-cv-page :global(.cv-note) {
      margin: 0 0 1.5rem;
      color: var(--muted);
      font-size: 0.98rem;
    }

    .page-panel.is-cv-page :global(.cv-index) {
      margin-top: 0;
      margin-bottom: 1.35rem;
      padding: 0.9rem 1rem;
    }

    .page-panel.is-cv-page :global(.cv-index-title) {
      margin: 0 0 0.6rem;
      color: var(--muted);
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .page-panel.is-cv-page :global(.cv-index-grid) {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(11.5rem, 1fr));
      gap: 0.45rem;
    }

    .page-panel.is-cv-page :global(.cv-index-grid a) {
      display: block;
      padding: 0.5rem 0.7rem;
      border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
      border-radius: 0.7rem;
      background: color-mix(in srgb, var(--surface) 94%, white 6%);
      color: var(--text);
      font-size: 0.88rem;
      line-height: 1.25;
      text-decoration: none;
      transition:
        border-color 160ms ease,
        transform 160ms ease,
        background-color 160ms ease;
    }

    .page-panel.is-cv-page :global(.cv-index-grid a:hover),
    .page-panel.is-cv-page :global(.cv-index-grid a:focus-visible) {
      border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
      background: color-mix(in srgb, var(--accent) 10%, var(--surface));
      transform: translateY(-1px);
    }

    .page-panel.is-cv-page :global(h2) {
      margin-top: 2.4rem;
      padding-top: 0.35rem;
      border-top: 1px solid var(--line);
      font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    }

    .page-panel.is-cv-page :global(h3) {
      margin-top: 1.8rem;
      font-size: 1.15rem;
    }

    .page-panel.is-cv-page :global(hr) {
      margin: 1rem 0 1.35rem;
      opacity: 0.55;
    }

    .page-panel.is-cv-page :global(table) {
      display: grid;
      gap: 0;
      border: 0;
      border-radius: 0;
      overflow: visible;
      background: transparent;
      box-shadow: none;
    }

    .page-panel.is-cv-page :global(td:first-child),
    .page-panel.is-cv-page :global(th:first-child) {
      width: var(--cv-label-column-width);
      min-width: 0;
      white-space: normal;
      overflow-wrap: anywhere;
      hyphens: auto;
      color: var(--muted);
      font-weight: 700;
    }

    .page-panel.is-cv-page :global(tbody),
    .page-panel.is-cv-page :global(thead) {
      display: grid;
      gap: 0.10rem;
    }

    .page-panel.is-cv-page :global(tbody) {
      margin-top: 0.10rem;
    }

    .page-panel.is-cv-page :global(tr) {
      display: grid;
      grid-template-columns: minmax(0, var(--cv-label-column-width)) minmax(0, 1fr);
      gap: 0;
      border: 1px solid var(--line);
      border-radius: 1.1rem;
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--surface) 95%, white 5%), var(--surface));
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .page-panel.is-cv-page :global(th) {
      padding: 1rem 1rem 1rem 1.1rem;
      border: 0;
      text-align: left;
      vertical-align: top;
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: normal;
      color: var(--text);
      text-transform: none;
      background: transparent;
    }

    .page-panel.is-cv-page :global(th:first-child) {
      font-weight: 700;
      color: var(--muted);
      border-right: 1px solid var(--line);
      background: color-mix(in srgb, var(--accent) 8%, var(--surface));
    }

    .page-panel.is-cv-page :global(td) {
      padding: 1rem 1rem 1rem 1.1rem;
      border: 0;
      vertical-align: top;
      background: transparent;
    }

    .page-panel.is-cv-page :global(td:first-child) {
      border-right: 1px solid var(--line);
      background: color-mix(in srgb, var(--accent) 8%, var(--surface));
    }

    .page-panel.is-cv-page :global(th + th),
    .page-panel.is-cv-page :global(td + td) {
      min-width: 0;
    }

    .page-panel.is-cv-page :global(.cv-plain-link) {
      display: inline-block;
      margin-top: 0.2rem;
    }

    .page-panel.is-cv-page :global(.cv-footer-card) {
      margin-top: 2rem;
      padding: 1.2rem 1.25rem;
      border: 1px solid var(--line);
      border-radius: 1.2rem;
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 7%, transparent), transparent 55%),
        var(--surface);
      box-shadow: var(--shadow);
    }

    .page-panel.is-cv-page :global(.cv-footer-card p:last-child) {
      margin-bottom: 0;
    }

    .media-hub {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .media-hub-intro {
      margin: 1.4rem 0 2rem;
      padding: 1.2rem;
      border: 1px solid var(--line);
      border-radius: 1.2rem;
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 8%, transparent), transparent 52%),
        var(--surface);
      box-shadow: var(--shadow);
    }

    .media-hub-intro p {
      margin: 0;
    }

    .media-hub-note {
      margin-top: 0.85rem !important;
      color: var(--muted);
    }

    .media-card {
      display: block;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 1.2rem;
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, white 6%), var(--surface));
      text-decoration: none;
      box-shadow: var(--shadow);
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        color 160ms ease,
        box-shadow 160ms ease;
    }

    .media-card:hover {
      color: var(--accent);
      border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
      transform: translateY(-1px);
      box-shadow: 0 18px 38px rgba(43, 29, 21, 0.08);
    }

    .media-card h2 {
      margin: 0 0 0.5rem;
      font-size: clamp(1.15rem, 2vw, 1.35rem);
      line-height: 1.2;
    }

    .media-card p {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.65;
    }

    @media (max-width: 720px) {
      .page-panel.is-cv-page :global(.cv-hero) {
        grid-template-columns: 1fr;
      }

      .page-panel.is-cv-page :global(.cv-photo-frame) {
        justify-self: start;
        width: min(15rem, 58vw);
      }

      .page-panel.is-cv-page :global(.cv-meta) {
        grid-template-columns: 1fr;
      }

      .page-panel.is-cv-page :global(tr) {
        grid-template-columns: 1fr;
      }

      .page-panel.is-cv-page :global(td:first-child),
      .page-panel.is-cv-page :global(th:first-child) {
        width: auto;
        white-space: normal;
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }

      .media-hub {
        grid-template-columns: 1fr;
      }
    }

    .page-panel.is-book-landing-page :global(.book-hero) {
      display: grid;
      grid-template-columns: minmax(13rem, 18rem) minmax(0, 1fr);
      gap: 1.6rem;
      align-items: start;
      margin: 1.4rem 0 2rem;
      padding: 1.3rem;
      border: 1px solid var(--line);
      border-radius: 1.3rem;
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 8%, transparent), transparent 50%),
        var(--surface);
      box-shadow: var(--shadow);
    }

    .page-panel.is-book-landing-page :global(.book-hero-cover),
    .page-panel.is-book-landing-page :global(.book-inline-art),
    .page-panel.is-book-landing-page :global(.author-portrait),
    .page-panel.is-book-landing-page :global(.book-end-cover) {
      margin: 0;
    }

    .page-panel.is-book-landing-page :global(.book-hero-cover img) {
      width: min(100%, 18rem);
      margin-inline: auto;
      box-shadow: var(--shadow);
    }

    .page-panel.is-book-landing-page :global(.book-hero-copy) > :first-child,
    .page-panel.is-book-landing-page :global(.book-purchase-card) > :first-child,
    .page-panel.is-book-landing-page :global(.reader-voices) > :first-child,
    .page-panel.is-book-landing-page :global(.author-card) > :first-child {
      margin-top: 0;
    }

    .page-panel.is-book-landing-page :global(.book-kicker) {
      margin: 0 0 0.8rem;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .page-panel.is-book-landing-page :global(.book-tagline) {
      margin: 0 0 1rem;
      font-size: clamp(1.3rem, 2.3vw, 1.75rem);
      line-height: 1.2;
    }

    .page-panel.is-book-landing-page :global(.book-quote) {
      margin: 1rem 0 0;
      padding-left: 1rem;
      border-left: 3px solid var(--accent);
      color: var(--muted);
      font-size: 1rem;
    }

    .page-panel.is-book-landing-page :global(.book-actions) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin: 1.2rem 0 0;
    }

    .page-panel.is-book-landing-page :global(.book-actions a) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 1rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: color-mix(in srgb, var(--surface) 92%, transparent);
      color: var(--text);
      font-weight: 600;
      text-decoration: none;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        color 160ms ease;
    }

    .page-panel.is-book-landing-page :global(.book-actions a:hover) {
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--accent) 32%, var(--line));
      color: var(--accent);
    }

    .page-panel.is-book-landing-page :global(.book-purchase-card),
    .page-panel.is-book-landing-page :global(.reader-voices),
    .page-panel.is-book-landing-page :global(.author-card) {
      margin: 1.5rem 0 2rem;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 1.15rem;
      background: color-mix(in srgb, var(--surface) 94%, transparent);
      box-shadow: 0 12px 30px rgba(43, 29, 21, 0.05);
    }

    .page-panel.is-book-landing-page :global(.book-badges) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      align-items: center;
      margin: 1rem 0;
    }

    .page-panel.is-book-landing-page :global(.book-badges a) {
      display: inline-flex;
      align-items: center;
    }

    .page-panel.is-book-landing-page :global(.book-badges img) {
      width: auto;
      height: 2.75rem;
      max-width: 9rem;
      border-radius: 0.45rem;
      box-shadow: none;
    }

    .page-panel.is-book-landing-page :global(.book-inline-art) {
      float: right;
      width: min(38%, 15rem);
      margin: 0.35rem 0 1rem 1.2rem;
    }

    .page-panel.is-book-landing-page :global(.book-inline-art img) {
      width: 100%;
      box-shadow: var(--shadow);
    }

    .page-panel.is-book-landing-page :global(.reader-voices blockquote) {
      margin: 1rem 0;
      padding: 0 0 0 1rem;
      border-left: 3px solid color-mix(in srgb, var(--accent) 70%, transparent);
      color: var(--text);
    }

    .page-panel.is-book-landing-page :global(.reader-voices hr) {
      margin: 1.25rem 0;
    }

    .page-panel.is-book-landing-page :global(.author-card) {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(11rem, 14rem);
      gap: 1.25rem;
      align-items: start;
    }

    .page-panel.is-book-landing-page :global(.author-portrait img) {
      width: 100%;
      max-width: 14rem;
      margin-left: auto;
      box-shadow: var(--shadow);
    }

    .page-panel.is-book-landing-page :global(.book-end-cover) {
      width: min(100%, 14rem);
      margin: 2rem auto 0;
    }

    .page-panel.is-book-landing-page :global(.book-end-cover img) {
      width: 100%;
      box-shadow: var(--shadow);
    }

    .page-panel.is-publications-page :global(.contents-card) {
      margin: 1.5rem 0 2rem;
      padding: 1.1rem 1.2rem;
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .page-panel.is-publications-page :global(.contents-card p) {
      margin-top: 0;
    }

    .page-panel.is-publications-page :global(.contents-card ul) {
      margin: 0.75rem 0 0;
      padding-left: 1.1rem;
    }

    .page-panel.is-publications-page :global(.contents-card li + li) {
      margin-top: 0.35rem;
    }

    .page-panel.is-publications-page :global(.contents-card ul ul) {
      margin-top: 0.35rem;
      padding-left: 1rem;
    }

    .page-panel.is-publications-page :global(.featured-book-section) {
      display: grid;
      grid-template-columns: minmax(12rem, 18rem) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
      margin: 1.25rem 0 1.5rem;
    }

    .page-panel.is-publications-page :global(.featured-book-cover) {
      margin: 0;
      text-align: left;
    }

    .page-panel.is-publications-page :global(.featured-book-cover img) {
      width: min(100%, 18rem);
      max-width: 100%;
      border-radius: 1rem;
      box-shadow: var(--shadow);
    }

    .page-panel.is-publications-page :global(.featured-book-body) > :first-child {
      margin-top: 0;
    }

    .page-panel.is-publications-page :global(.featured-book-body) > :last-child {
      margin-bottom: 0;
    }

    .page-panel.is-publications-page :global(.book-badges) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      align-items: center;
      justify-content: flex-start;
      margin: 1rem 0;
    }

    .page-panel.is-publications-page :global(.book-badges a) {
      display: inline-flex;
      align-items: center;
    }

    .page-panel.is-publications-page :global(.book-badges img) {
      width: auto;
      height: 2.75rem;
      max-width: 9rem;
      border-radius: 0.45rem;
      box-shadow: none;
    }

    .page-panel.is-publications-page :global(h2) {
      margin-top: 3rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--line);
      font-size: clamp(1.6rem, 2.4vw, 2.1rem);
      letter-spacing: 0.01em;
    }

    .page-panel.is-publications-page :global(h3) {
      display: block;
      margin: 2rem 0 1rem;
      padding: 0 0 0 0.9rem;
      border-left: 3px solid var(--accent);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      font-size: 1.08rem;
      line-height: 1.3;
    }

    .page-panel.is-publications-page :global(.publication-archive) {
      margin-top: 1.5rem;
    }

    .page-panel.is-publications-page :global(.archive-intro) {
      margin: 0 0 1.5rem;
      color: var(--muted);
      font-size: 1rem;
    }

    .page-panel.is-publications-page :global(.publication-archive > p:has(> a[id])) {
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      line-height: 0;
    }

    .page-panel.is-publications-page :global(.publication-archive > p:not(.archive-intro):not(:has(> a[id]))) {
