---
import { getCollection, render } from "astro:content";
import ContactForm from "../../../../components/ContactForm.astro";
import SiteLayout from "../../../../layouts/SiteLayout.astro";
import { getMediaHubItems, type Lang } from "../../../../lib/site";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  return pages.map((page) => {
    const [lang, slug] = page.id.split("/");

    return {
      params: { lang, slug },
      props: { page },
    };
  });
}

const { page } = Astro.props;
const { Content } = await render(page);
const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug ?? "";
const isMediaHub = slug === "media-presence" || slug === "presencia-en-medios";
const isContactPage = slug === "contact-me" || slug === "contacto";
const isPublicationsPage = slug === "publications" || slug === "publicaciones";
const mediaHubItems = isMediaHub ? getMediaHubItems(lang) : [];
---

<SiteLayout lang={lang} title={page.data.title}>
  <article class:list={["panel prose page-panel", isPublicationsPage && "is-publications-page"]}>
    <h1>{page.data.title}</h1>
    {isMediaHub ? (
      <div class="media-hub">
        {mediaHubItems.map((item) => (
          <a class="media-card" href={item.href}>
            <h2>{item.title}</h2>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <>
        <Content />
        {isContactPage && <ContactForm lang={lang} />}
      </>
    )}
  </article>

  <style>
    .page-panel {
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
    }

    .media-hub {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .media-card {
      display: block;
      padding: 1.2rem;
      border: 1px solid var(--line);
      border-radius: 1.1rem;
      background: var(--surface);
      text-decoration: none;
      box-shadow: var(--shadow);
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        color 160ms ease;
    }

    .media-card:hover {
      color: var(--accent);
      border-color: rgba(161, 79, 42, 0.28);
      transform: translateY(-1px);
    }

    .media-card h2 {
      margin: 0 0 0.5rem;
      font-size: 1.2rem;
      line-height: 1.2;
    }

    .media-card p {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.65;
    }

    @media (max-width: 720px) {
      .media-hub {
        grid-template-columns: 1fr;
      }
    }

    .page-panel.is-publications-page :global(.contents-card) {
      margin: 1.5rem 0 2rem;
      padding: 1.1rem 1.2rem;
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .page-panel.is-publications-page :global(.contents-card p) {
      margin-top: 0;
    }

    .page-panel.is-publications-page :global(.contents-card ul) {
      margin: 0.75rem 0 0;
      padding-left: 1.1rem;
    }

    .page-panel.is-publications-page :global(.contents-card li + li) {
      margin-top: 0.35rem;
    }

    .page-panel.is-publications-page :global(.contents-card ul ul) {
      margin-top: 0.35rem;
      padding-left: 1rem;
    }

    .page-panel.is-publications-page :global(.featured-book-section) {
      display: grid;
      grid-template-columns: minmax(12rem, 18rem) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
      margin: 1.25rem 0 1.5rem;
    }

    .page-panel.is-publications-page :global(.featured-book-cover) {
      margin: 0;
      text-align: left;
    }

    .page-panel.is-publications-page :global(.featured-book-cover img) {
      width: min(100%, 18rem);
      max-width: 100%;
      border-radius: 1rem;
      box-shadow: var(--shadow);
    }

    .page-panel.is-publications-page :global(.featured-book-body) > :first-child {
      margin-top: 0;
    }

    .page-panel.is-publications-page :global(.featured-book-body) > :last-child {
      margin-bottom: 0;
    }

    .page-panel.is-publications-page :global(.book-badges) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      align-items: center;
      justify-content: flex-start;
      margin: 1rem 0;
    }

    .page-panel.is-publications-page :global(.book-badges a) {
      display: inline-flex;
      align-items: center;
    }

    .page-panel.is-publications-page :global(.book-badges img) {
      width: auto;
      height: 2.75rem;
      max-width: 9rem;
      border-radius: 0.45rem;
      box-shadow: none;
    }

    .page-panel.is-publications-page :global(h2) {
      margin-top: 3rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--line);
      font-size: clamp(1.6rem, 2.4vw, 2.1rem);
      letter-spacing: 0.01em;
    }

    .page-panel.is-publications-page :global(h3) {
      display: block;
      margin: 2rem 0 1rem;
      padding: 0 0 0 0.9rem;
      border-left: 3px solid var(--accent);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      font-size: 1.08rem;
      line-height: 1.3;
    }

    .page-panel.is-publications-page :global(.publication-archive) {
      margin-top: 1.5rem;
    }

    .page-panel.is-publications-page :global(.archive-intro) {
      margin: 0 0 1.5rem;
      color: var(--muted);
      font-size: 1rem;
    }

    .page-panel.is-publications-page :global(.publication-archive > p:has(> a[id])) {
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      line-height: 0;
    }

    .page-panel.is-publications-page :global(.publication-archive > p:not(.archive-intro):not(:has(> a[id]))) {
      margin: 0 0 1rem;
      padding: 1rem 1.1rem;
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: color-mix(in srgb, var(--surface) 88%, transparent);
      box-shadow: 0 12px 30px rgba(43, 29, 21, 0.05);
      line-height: 1.7;
    }

    .page-panel.is-publications-page :global(.publication-archive > p:not(.archive-intro):not(:has(> a[id])) strong) {
      color: var(--text);
    }

    .page-panel.is-publications-page :global(.publication-archive > p:not(.archive-intro):not(:has(> a[id])) a) {
      text-decoration-thickness: 0.08em;
      text-underline-offset: 0.14em;
    }

    .page-panel.is-publications-page :global(.publication-archive > a[id]) {
      display: block;
      margin-top: 0.5rem;
    }

    @media (max-width: 720px) {
      .page-panel.is-publications-page :global(.contents-card) {
        padding: 1rem;
      }

      .page-panel.is-publications-page :global(.featured-book-section) {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .page-panel.is-publications-page :global(.featured-book-cover img) {
        width: min(100%, 16rem);
      }

      .page-panel.is-publications-page :global(.book-badges) {
        gap: 0.65rem;
      }

      .page-panel.is-publications-page :global(.book-badges img) {
        height: 2.4rem;
        max-width: 7.5rem;
      }

      .page-panel.is-publications-page :global(h3) {
        font-size: 0.96rem;
        padding-left: 0.75rem;
      }

      .page-panel.is-publications-page :global(.publication-archive > p:not(.archive-intro):not(:has(> a[id]))) {
        padding: 0.9rem 0.95rem;
      }
    }
  </style>
</SiteLayout>
