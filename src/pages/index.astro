---
import { getCollection } from "astro:content";
import "../styles/fonts.css";
import "../styles/site-chrome.css";
import BlogPostRow from "../components/BlogPostRow.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ThemeBoot from "../components/ThemeBoot.astro";
import { getPostExcerpt } from "../lib/blog";
import { getNavItems, languages, sectionRoutes, siteCopy, siteTitle, siteUrl } from "../lib/site";

const englishNav = getNavItems("en");
const spanishNav = getNavItems("es");

const latestPostsByLanguage = await Promise.all(
  (["en", "es"] as const).map(async (lang) => {
    const languageCopy = siteCopy[lang];
    const posts = (await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`)))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, 3)
      .map((post) => {
        const [, year, slug] = post.id.split("/");

        return {
          title: post.data.title,
          date: post.data.date,
          href: `/${lang}/blog/${year}/${slug}/`,
          excerpt: getPostExcerpt(post.body),
        };
      });

    return {
      lang,
      label: languages.find((entry) => entry.code === lang)?.label ?? lang,
      latestLabel: languageCopy.latestPostsLabel,
      viewAllLabel: languageCopy.viewAllLabel,
      route: sectionRoutes[lang].blog,
      formatter: new Intl.DateTimeFormat(languageCopy.dateLocale, {
        year: "numeric",
        month: "short",
        day: "numeric",
      }),
      posts,
    };
  }),
);
const canonicalUrl = new URL("/", siteUrl).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Conscious Robots - Raúl Arrabales personal website and blog in English and Spanish."
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta
      property="og:description"
      content="Conscious Robots - Raúl Arrabales personal website and blog in English and Spanish."
    />
    <meta property="og:type" content="website" />
    <title>{siteTitle}</title>
    <ThemeBoot />
    <style>
      .hero,
      .language-card {
        border: 1px solid var(--line);
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .hero {
        margin-top: 1.5rem;
        padding: clamp(1.5rem, 4vw, 3rem);
        border-radius: 1.75rem;
      }

      .eyebrow {
        margin: 0 0 1rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.5rem, 6vw, 5.2rem);
        line-height: 0.95;
      }

      .hero-title {
        font-size: clamp(1.65rem, 5vw, 4.35rem);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .lede {
        max-width: 42rem;
        color: var(--muted);
        font-size: 1.14rem;
        line-height: 1.7;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.25rem;
      }

      .intro-card {
        max-width: 44rem;
        margin-top: 1.35rem;
        padding: 1rem 1.1rem;
        border: 1px solid var(--line);
        border-radius: 1.1rem;
        background: linear-gradient(135deg, var(--surface-strong), var(--surface-soft));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.24);
      }

      .intro-card p {
        margin: 0;
        color: var(--text);
        font-size: 1rem;
        line-height: 1.65;
      }

      .cta-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.7rem 1rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background:
          linear-gradient(135deg, var(--surface-strong), var(--surface-soft));
        text-decoration: none;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          color 160ms ease,
          background 160ms ease;
      }

      .cta-link:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-1px);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.1rem;
        margin-top: 1.5rem;
      }

      .latest-grid {
        margin-top: 1.1rem;
      }

      .language-card {
        padding: 1.4rem;
        border-radius: 1.5rem;
      }

      .language-card h2 {
        margin: 0 0 0.4rem;
        font-size: 1.7rem;
      }

      .language-card p {
        color: var(--muted);
        line-height: 1.7;
      }

      .menu {
        margin-top: 1rem;
      }

      .menu ul {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        width: 100%;
        min-height: 2.5rem;
        padding: 0.55rem 0.9rem;
        border: 1px solid var(--line);
        border-radius: 0.5rem;
        background: var(--surface-strong);
        justify-content: center;
        text-decoration: none;
      }

      .menu-link:hover {
        color: var(--accent);
      }

      .latest-head {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1rem;
      }

      .latest-head h2 {
        margin: 0;
        font-size: 1.4rem;
      }

      .latest-link {
        color: var(--muted);
        text-decoration: none;
      }

      .latest-link:hover {
        color: var(--accent);
      }

      .latest-list {
        display: grid;
        gap: 0.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .latest-item {
        border-top: 1px solid var(--line);
        padding-top: 0.7rem;
      }

      .latest-item:first-child {
        border-top: 0;
        padding-top: 0;
      }

      @media (max-width: 780px) {
        .hero-title {
          font-size: clamp(1.25rem, 5.8vw, 2.4rem);
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .menu ul {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body id="top">
    <div class="shell">
      <SiteHeader brandHref="/" brandLabel="Conscious Robots" />

      <main>
        <section class="hero">
          <p class="eyebrow">Thoughts, publications, and media</p>
          <h1 class="hero-title">Raúl Arrabales Moreno, PhD</h1>
          <p class="lede">
            Cognitive Science | Artificial Intelligence | Machine Consciousness 
          </p>
          <div class="intro-card">
            <p>
              Raúl Arrabales Moreno is an AI expert, psychologist, researcher, and educator
              focused on helping organizations turn Artificial Intelligence into practical and
              responsible value
            </p>
          </div>
          <div class="cta-row" aria-label="Language landing pages">
            <a class="cta-link" href="/en/">Enter in English</a>
            <a class="cta-link" href="/es/">Entrar en español</a>
          </div>
        </section>

        <section class="grid">
          <article class="language-card">
            <p class="eyebrow">English</p>
            <nav class="menu" aria-label="English sections">
              <ul>
                {englishNav.map((item) => (
                  <li><a class="menu-link" href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </nav>
          </article>

          <article class="language-card">
            <p class="eyebrow">Español</p>
          <nav class="menu" aria-label="Secciones en español">
              <ul>
                {spanishNav.map((item) => (
                  <li><a class="menu-link" href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </nav>
          </article>
        </section>

        <section class="grid latest-grid" aria-label="Latest posts by language">
          {latestPostsByLanguage.map((group) => (
            <article class="language-card">
              <div class="latest-head">
                <div>
                  <p class="eyebrow">{group.label}</p>
                  <h2>{group.latestLabel}</h2>
                </div>
                <a class="latest-link" href={group.route}>
                  {group.viewAllLabel}
                </a>
              </div>

              <ul class="latest-list">
                {group.posts.map((post) => (
                  <li class="latest-item">
                    <BlogPostRow
                      variant="compact"
                      title={post.title}
                      href={post.href}
                      date={post.date}
                      formatter={group.formatter}
                      excerpt={post.excerpt}
                    />
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </section>
      </main>

      <SiteFooter updatedAt={new Date()} />
    </div>
  </body>
</html>
