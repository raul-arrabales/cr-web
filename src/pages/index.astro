---
import { getNavItems, languages, sectionRoutes } from "../lib/site";

const englishNav = getNavItems("en");
const spanishNav = getNavItems("es");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Raúl Arrabales personal website and bilingual blog in English and Spanish."
    />
    <title>Raúl Arrabales</title>
    <style>
      :root {
        --bg: #f5f1e8;
        --surface: rgba(255, 255, 255, 0.82);
        --surface-strong: rgba(255, 255, 255, 0.94);
        --text: #1f1a17;
        --muted: #61574f;
        --line: rgba(55, 42, 34, 0.14);
        --accent: #a14f2a;
        --shadow: 0 24px 70px rgba(43, 29, 21, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(161, 79, 42, 0.16), transparent 35%),
          radial-gradient(circle at top right, rgba(89, 108, 137, 0.14), transparent 30%),
          linear-gradient(180deg, #faf7f1 0%, var(--bg) 100%);
      }

      body {
        margin: 0;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.25rem 0 4rem;
      }

      .topbar,
      .hero,
      .language-card {
        border: 1px solid var(--line);
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .topbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        align-items: center;
        justify-content: space-between;
        padding: 0.95rem 1rem;
        border-radius: 1.25rem;
        backdrop-filter: blur(14px);
      }

      .brand {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-decoration: none;
      }

      .language-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .pill,
      .menu-link,
      .cta {
        display: inline-flex;
        align-items: center;
        min-height: 2.5rem;
        padding: 0.55rem 0.9rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface-strong);
        text-decoration: none;
      }

      .hero {
        margin-top: 1.5rem;
        padding: clamp(1.5rem, 4vw, 3rem);
        border-radius: 1.75rem;
      }

      .eyebrow {
        margin: 0 0 1rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.5rem, 6vw, 5.2rem);
        line-height: 0.95;
      }

      .lede {
        max-width: 42rem;
        color: var(--muted);
        font-size: 1.14rem;
        line-height: 1.7;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.25rem;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.1rem;
        margin-top: 1.5rem;
      }

      .language-card {
        padding: 1.4rem;
        border-radius: 1.5rem;
      }

      .language-card h2 {
        margin: 0 0 0.4rem;
        font-size: 1.7rem;
      }

      .language-card p {
        color: var(--muted);
        line-height: 1.7;
      }

      .menu {
        margin-top: 1rem;
      }

      .menu ul {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .menu-link {
        width: 100%;
        justify-content: center;
      }

      .pill:hover,
      .menu-link:hover,
      .cta:hover,
      .brand:hover {
        color: var(--accent);
      }

      @media (max-width: 780px) {
        .shell {
          width: min(100% - 1rem, 1120px);
          padding-top: 0.75rem;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .menu ul {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">Raúl Arrabales</a>

        <nav class="language-pills" aria-label="Languages">
          {languages.map((language) => (
            <a class="pill" href={`/${language.code}/`}>{language.label}</a>
          ))}
        </nav>
      </header>

      <main>
        <section class="hero">
          <p class="eyebrow">Bilingual site</p>
          <h1>Thoughts, publications, and media across English and Spanish.</h1>
          <p class="lede">
            Choose a language to explore the blog, publications, media presence, and
            curriculum vitae. Each language section is maintained independently.
          </p>

          <div class="cta-row">
            <a class="cta" href={sectionRoutes.en.home}>Enter English site</a>
            <a class="cta" href={sectionRoutes.es.home}>Entrar en español</a>
          </div>
        </section>

        <section class="grid">
          <article class="language-card">
            <p class="eyebrow">English</p>
            <h2>English</h2>
            <p>{languages[0].description}</p>
            <nav class="menu" aria-label="English sections">
              <ul>
                {englishNav.map((item) => (
                  <li><a class="menu-link" href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </nav>
          </article>

          <article class="language-card">
            <p class="eyebrow">Español</p>
            <h2>Español</h2>
            <p>{languages[1].description}</p>
            <nav class="menu" aria-label="Secciones en español">
              <ul>
                {spanishNav.map((item) => (
                  <li><a class="menu-link" href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </nav>
          </article>
        </section>
      </main>
    </div>
  </body>
</html>
