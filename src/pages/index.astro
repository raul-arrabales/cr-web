---
import "../styles/fonts.css";
import { getNavItems, languages, sectionRoutes } from "../lib/site";

const englishNav = getNavItems("en");
const spanishNav = getNavItems("es");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Conscious Robots - Raúl Arrabales personal website and blog in English and Spanish."
    />
    <title>Conscious Robots</title>
    <style>
      :root {
        --bg: #f5f1e8;
        --surface: rgba(255, 255, 255, 0.82);
        --surface-strong: rgba(255, 255, 255, 0.94);
        --text: #1f1a17;
        --muted: #61574f;
        --line: rgba(55, 42, 34, 0.14);
        --accent: #a14f2a;
        --shadow: 0 24px 70px rgba(43, 29, 21, 0.08);
        --brand-font: "Orbitron", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "Space Grotesk", sans-serif;
        color: var(--text);
        background: #f8f4ec;
      }

      body {
        position: relative;
        margin: 0;
        min-height: 100vh;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          radial-gradient(circle at top left, rgba(161, 79, 42, 0.1), transparent 32%),
          radial-gradient(circle at top right, rgba(89, 108, 137, 0.08), transparent 28%),
          linear-gradient(180deg, #faf7f1 0%, var(--bg) 100%);
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.25rem 0 4rem;
      }

      .topbar,
      .hero,
      .language-card {
        border: 1px solid var(--line);
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .topbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        align-items: center;
        justify-content: space-between;
        padding: 0.95rem 1rem;
        border-radius: 1.25rem;
        backdrop-filter: blur(14px);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        flex: 0 1 auto;
        min-width: 0;
        max-width: 100%;
        padding: 0.15rem 0;
        font-family: var(--brand-font);
        font-size: clamp(1.4rem, 3.2vw, 2.5rem);
        font-weight: 700;
        letter-spacing: 0.04em;
        line-height: 1.05;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .language-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        justify-content: flex-end;
        flex: 0 0 auto;
      }

      .pill,
      .menu-link,
      .cta {
        display: inline-flex;
        align-items: center;
        min-height: 2.5rem;
        padding: 0.55rem 0.9rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface-strong);
        text-decoration: none;
      }

      .hero {
        margin-top: 1.5rem;
        padding: clamp(1.5rem, 4vw, 3rem);
        border-radius: 1.75rem;
      }

      .eyebrow {
        margin: 0 0 1rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.5rem, 6vw, 5.2rem);
        line-height: 0.95;
      }

      .hero-title {
        font-size: clamp(1.65rem, 5vw, 4.35rem);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .lede {
        max-width: 42rem;
        color: var(--muted);
        font-size: 1.14rem;
        line-height: 1.7;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.25rem;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.1rem;
        margin-top: 1.5rem;
      }

      .language-card {
        padding: 1.4rem;
        border-radius: 1.5rem;
      }

      .language-card h2 {
        margin: 0 0 0.4rem;
        font-size: 1.7rem;
      }

      .language-card p {
        color: var(--muted);
        line-height: 1.7;
      }

      .menu {
        margin-top: 1rem;
      }

      .menu ul {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .menu-link {
        width: 100%;
        justify-content: center;
      }

      .pill:hover,
      .menu-link:hover,
      .cta:hover,
      .brand:hover {
        color: var(--accent);
      }

      @media (max-width: 780px) {
        .shell {
          width: min(100% - 1rem, 1120px);
          padding-top: 0.75rem;
        }

        .brand {
          font-size: clamp(1.2rem, 6vw, 1.8rem);
          letter-spacing: 0.03em;
        }

        .hero-title {
          font-size: clamp(1.25rem, 5.8vw, 2.4rem);
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .menu ul {
          grid-template-columns: 1fr;
        }

        .language-pills {
          justify-content: flex-start;
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">Conscious Robots</a>

        <nav class="language-pills" aria-label="Languages">
          {languages.map((language) => (
            <a class="pill" href={`/${language.code}/`}>{language.label}</a>
          ))}
        </nav>
      </header>

      <main>
        <section class="hero">
          <p class="eyebrow">Thoughts, publications, and media</p>
          <h1 class="hero-title">Raúl Arrabales Moreno, PhD</h1>
          <p class="lede">
            Cognitive Science | Artificial Intelligence | Machine Consciousness 
          </p>
        </section>

        <section class="grid">
          <article class="language-card">
            <p class="eyebrow">English</p>
            <nav class="menu" aria-label="English sections">
              <ul>
                {englishNav.map((item) => (
                  <li><a class="menu-link" href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </nav>
          </article>

          <article class="language-card">
            <p class="eyebrow">Español</p>
            <nav class="menu" aria-label="Secciones en español">
              <ul>
                {spanishNav.map((item) => (
                  <li><a class="menu-link" href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </nav>
          </article>
        </section>
      </main>
    </div>
  </body>
</html>
